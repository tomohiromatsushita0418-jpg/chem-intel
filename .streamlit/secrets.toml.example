# Streamlit Community Cloud では「App settings > Secrets」にこの内容を貼り付ける。
# ローカルで使う場合は .streamlit/secrets.toml にコピーして値を埋める（gitには上げない）。

ANTHROPIC_API_KEY = "sk-ant-..."        # 必須：調査エンジン
COMTRADE_KEY = ""                        # 任意：UN Comtrade subscription key（推奨）
DATABASE_URL = ""                        # 任意：履歴永続化用 Postgres（例: Supabase）
RESEARCH_MODEL = "claude-sonnet-4-6"     # 任意
SYNTHESIS_MODEL = "claude-opus-4-8"      # 任意
WEB_SEARCH_MAX_USES = "8"                # 任意：1セクションあたりの検索上限
